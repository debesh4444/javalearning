public class Sample {

  
    public static int add(int a, int b) {
        return a + b;
    }

   
    public static int divide(int a, int b) {
        return a / b;
    }

    public static void main(String[] args) {

        int sum = add(8, 2);     
        int div = divide(8, 2);    
        System.out.println("Sum = " + sum);
        System.out.println("Division = " + div);
    }
}
